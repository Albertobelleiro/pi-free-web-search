{
  "name": "pi-free-web-search",
  "version": "0.2.0",
  "description": "Free, hybrid, browser-aware web search and content extraction package for Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Alberto Belleiro",
  "homepage": "https://github.com/Albertobelleiro/pi-free-web-search#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Albertobelleiro/pi-free-web-search.git"
  },
  "bugs": {
    "url": "https://github.com/Albertobelleiro/pi-free-web-search/issues"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "src",
    "extensions",
    "skills",
    "scripts",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "web-search",
    "browser-automation",
    "research"
  ],
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test tests/*.test.ts",
    "check": "bun run typecheck && bun run test",
    "smoke": "bun run scripts/smoke-test.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.53.2",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/turndown": "^5.0.5",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.62.0 <1",
    "@mariozechner/pi-coding-agent": ">=0.62.0 <1",
    "@mariozechner/pi-tui": ">=0.62.0 <1",
    "@sinclair/typebox": ">=0.34.0 <1"
  },
  "pi": {
    "extensions": [
      "extensions/free-web-search/index.ts"
    ],
    "skills": [
      "skills/free-web-researcher"
    ]
  }
